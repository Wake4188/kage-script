/* ─── Helpers ─── */
function simClass(v) {
  if (v >= 0.9) return 'sim-green';
  if (v >= 0.7) return 'sim-yellow';
  return 'sim-red';
}
function trunc(str, n) {
  return str.length > n ? str.slice(0, n - 1) + '…' : str;
}
function fmtSim(v) {
  return (v * 100).toFixed(1) + '%';
}

/* ─── Render table ─── */
let currentFilter = 'all';
let currentSearch = '';
let currentSort = 'index';

function applyFilter(d) {
  if (currentFilter === 'new-wins') return d.newSim > d.oldSim;
  if (currentFilter === 'old-wins') return d.oldSim > d.newSim;
  if (currentFilter === 'tied')     return Math.abs(d.newSim - d.oldSim) < 0.001;
  if (currentFilter === 'exact-new') return d.newSim >= 1.0;
  if (currentFilter === 'failed')   return d.newSim < 0.6;
  return true;
}
function applySearch(d) {
  if (!currentSearch) return true;
  return d.orig.toLowerCase().includes(currentSearch.toLowerCase());
}
function applySort(arr) {
  if (currentSort === 'new-desc') return [...arr].sort((a,b) => b.newSim - a.newSim);
  if (currentSort === 'new-asc')  return [...arr].sort((a,b) => a.newSim - b.newSim);
  if (currentSort === 'delta-desc') return [...arr].sort((a,b) => (b.newSim-b.oldSim) - (a.newSim-a.oldSim));
  return [...arr].sort((a,b) => a.i - b.i);
}

function renderTable() {
  const visible = applySort(DATA.filter(d => applyFilter(d) && applySearch(d)));
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';
  visible.forEach(d => {
    const delta = d.newSim - d.oldSim;
    const dClass = Math.abs(delta) < 0.001 ? 'delta-zero' : delta > 0 ? 'delta-pos' : 'delta-neg';
    const dSign  = delta > 0.0005 ? '+' : delta < -0.0005 ? '−' : '±';
    const dVal   = Math.abs(delta * 100).toFixed(1) + '%';
    const newStar = d.newSim >= 1.0 ? '<span class="exact-star" title="Exact match">&#9670;</span>' : '';
    const oldStar = d.oldSim >= 1.0 ? '<span class="exact-star" title="Exact match">&#9670;</span>' : '';
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${d.i}</td>
      <td><span class="cell-text orig" title="${d.orig.replace(/"/g,'&quot;')}">${trunc(d.orig, 62)}</span></td>
      <td><span class="cell-text dimmed" title="${d.old.replace(/"/g,'&quot;')}">${trunc(d.old, 55)}</span></td>
      <td><span class="cell-text" title="${d.nw.replace(/"/g,'&quot;')}">${trunc(d.nw, 55)}</span></td>
      <td><span class="sim-badge ${simClass(d.oldSim)}">${fmtSim(d.oldSim)}${oldStar}</span></td>
      <td><span class="sim-badge ${simClass(d.newSim)}">${fmtSim(d.newSim)}${newStar}</span></td>
      <td><span class="delta-badge ${dClass}">${dSign}${dVal}</span></td>
    </tr>`);
  });
  document.getElementById('tableFooter').textContent =
    `Showing ${visible.length} of ${DATA.length}`;
}

/* ─── Controls wiring ─── */
document.getElementById('filterBtns').addEventListener('click', e => {
  const btn = e.target.closest('.filter-btn');
  if (!btn) return;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentFilter = btn.dataset.filter;
  renderTable();
  saveState();
});

document.getElementById('searchInput').addEventListener('input', e => {
  currentSearch = e.target.value;
  renderTable();
  saveState();
});

document.getElementById('sortSelect').addEventListener('change', e => {
  currentSort = e.target.value;
  renderTable();
  saveState();
});

renderTable();

/* ─── Persistence ─── */
const STORAGE_KEY = `artifact-state:${location.pathname}`;
const STATE_SCHEMA_VERSION = 1;
const ARTIFACT_REVISION = '1.0.0';
let artifactRevision = ARTIFACT_REVISION;
const saveStatusEl = document.getElementById('saveStatus');
let inFlightSave = null;
let queuedState = null;

function setSaveStatus(status) {
  saveStatusEl.className = 'save-status';
  if (status === 'Saving...') { saveStatusEl.classList.add('saving'); saveStatusEl.textContent = 'Saving...'; }
  else if (status === 'Saved') { saveStatusEl.classList.add('saved'); saveStatusEl.textContent = 'Saved'; setTimeout(() => { if (saveStatusEl.textContent === 'Saved') saveStatusEl.textContent = ''; }, 2500); }
  else if (status === 'Save failed') { saveStatusEl.classList.add('failed'); saveStatusEl.textContent = 'Save failed'; }
  else { saveStatusEl.textContent = status; }
}

async function persistState(state, { keepalive = false } = {}) {
  setSaveStatus('Saving...');
  try {
    const res = await fetch('/artifacts/state', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      keepalive,
      body: JSON.stringify({ path: location.pathname, state_json: state, state_schema_version: STATE_SCHEMA_VERSION, artifact_revision: artifactRevision }),
    });
    if (res.ok) {
      const payload = await res.json();
      artifactRevision = payload.artifact_revision ?? payload.state?.artifact_revision ?? artifactRevision;
      setSaveStatus('Saved');
    } else {
      setSaveStatus('Save failed');
    }
  } catch { setSaveStatus('Save failed'); }
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
}

async function flushSaveQueue(options) {
  while (queuedState) {
    const next = queuedState; queuedState = null;
    await persistState(next, options);
  }
  inFlightSave = null;
}

function saveState() {
  const state = { filter: currentFilter, search: currentSearch, sort: currentSort };
  queuedState = state;
  if (!inFlightSave) inFlightSave = flushSaveQueue();
}

function flushPendingSave() {
  if (!queuedState) return;
  const next = queuedState; queuedState = null;
  void persistState(next, { keepalive: true });
}

window.addEventListener('pagehide', flushPendingSave);
document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'hidden') flushPendingSave(); });

async function loadPersistedState() {
  let saved = {};
  try {
    const res = await fetch(`/artifacts/state?path=${encodeURIComponent(location.pathname)}`, { cache: 'no-store' });
    if (res.ok) {
      const payload = await res.json();
      artifactRevision = payload.artifact_revision ?? payload.state?.artifact_revision ?? artifactRevision;
      saved = payload.state?.state_json ?? {};
    }
  } catch {
    try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}
  }
  if (saved.filter) {
    currentFilter = saved.filter;
    const btn = document.querySelector(`.filter-btn[data-filter="${currentFilter}"]`);
    if (btn) { document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }
  }
  if (saved.search !== undefined) { currentSearch = saved.search; document.getElementById('searchInput').value = saved.search; }
  if (saved.sort) { currentSort = saved.sort; document.getElementById('sortSelect').value = saved.sort; }
  renderTable();
}

loadPersistedState();
</script>
